        <linkedMain/>
        <Text>
          <linkedMain/>
          <style>Title</style>
          <text>Święty, święty, święty!</text>
          </Text>
        <Text>
          <linkedMain/>
          <style>Subtitle</style>
          <size>9</size>
          <text>&quot;(...) I bez odpoczynku, dniem i nocą mówią: 
Święty, święty, święty, 
Pan Bóg Wszechmogący, (...)&quot; Obj. 4:8</text>
          </Text>
        <Text>
          <linkedMain/>
          <style>Lyricist</style>
          <text>Reginald Heber 1783-1826</text>
          </Text>
