        <linkedMain/>
        <Text>
          <linkedMain/>
          <style>Title</style>
          <text>O, mów, czy krew Swą wylał Pan</text>
          </Text>
        <Text>
          <linkedMain/>
          <style>Subtitle</style>
          <size>9</size>
          <text>Chrystus... który mnie umiłował i wydał za mnie samego siebie. Gal.2:20</text>
          </Text>
