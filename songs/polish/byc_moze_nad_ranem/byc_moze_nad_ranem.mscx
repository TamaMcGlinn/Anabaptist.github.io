        <linkedMain/>
        <Text>
          <linkedMain/>
          <style>Title</style>
          <text>Być może nad ranem</text>
          </Text>
        <Text>
          <linkedMain/>
          <style>Subtitle</style>
          <size>9</size>
          <offset x="-9.93171" y="9.25512"/>
          <text>&quot;Czuwajcie więc, bo nie wiecie, kiedy pan domu przyjdzie: 
wieczorem czy o północy, gdy pieją koguty czy rano.&quot; Marka 13:35</text>
          </Text>
        <Text>
